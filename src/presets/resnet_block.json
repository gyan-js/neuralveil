{
    "version": "1.0",
    "presetName": "ResNet Block",
    "format": "NCHW",
    "inputShape": [1, 3, 224, 224],
    "nodes": [
      { "id": "input",   "type": "Input",   "position": { "x": 300, "y": 30  }, "config": {} },
